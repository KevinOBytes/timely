# App Environment
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Authentication & Security
AUTH_SHARED_KEY="replace_with_secure_random_key"
AUTH_COOKIE_SECRET="replace_with_secure_cookie_secret"
AUDIT_SIGNING_SECRET="replace_with_secure_audit_secret"

# Email Delivery (Resend)
RESEND_API_KEY=""
RESEND_LOGIN_FROM="logins@yourdomain.com"

# Database (PostgreSQL / NeonDB)
DATABASE_URL="postgresql://user:password@host:port/neondb?sslmode=require"

# Key-Value Store (Redis / Upstash / Mock)
UPSTASH_REDIS_REST_URL="https://mock-redis.upstash.io"
UPSTASH_REDIS_REST_TOKEN="mock_redis_token_12345"
# Vercel KV aliases are also supported:
# KV_REST_API_URL="https://..."
# KV_REST_API_TOKEN="..."

# Stripe Settings
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_SECRET_KEY=""

# Stripe Webhooks (Get this from the Stripe dashboard under 'Webhooks')
# To test locally during development, run: stripe listen --forward-to localhost:3000/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=""

# Observability (optional; the app starts and readiness degrades gracefully without Sentry)
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# Stripe Pricing IDs
# Internal plan IDs stay stable for database compatibility:
# pro = Starter ($9/workspace/month), smb = Studio ($29/workspace/month), enterprise = Business ($79/workspace/month).
# Get these IDs from the Stripe Dashboard > Products > Product > Price ID (e.g. price_1Habc...)
STRIPE_PRO_PRICE_ID="price_12345_starter_monthly"
STRIPE_SMB_PRICE_ID="price_12345_studio_monthly"
STRIPE_ENTERPRISE_PRICE_ID="price_12345_business_monthly"

# External Data
EXCHANGE_RATE_API_URL="https://api.exchangerate.host/latest"

# App Features
ALLOW_SELF_REGISTRATION="true"
ALLOW_BOOTSTRAP_OWNER="true"
